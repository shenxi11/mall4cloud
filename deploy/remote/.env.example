# 模块名: remote_deploy_env_example
# 功能概述: 远程 Docker 部署的环境变量示例，不保存服务器登录密码。
# 对外接口: deploy/remote/deploy.sh 与 docker-compose.prod.yml
# 依赖关系: Docker Compose 环境变量
# 输入输出: 输入部署路径、服务器 IP 和公开入口，输出 compose 可读取的变量。
# 异常与错误: 真实 .env 缺失时 deploy.sh 会用默认值补齐。
# 维护说明: 复制为 .env 后按服务器实际情况调整；不要把真实敏感凭据提交到仓库。

SERVER_IP=64.90.3.109
PUBLIC_PORT=6688
PUBLIC_ORIGIN=http://64.90.3.109:6688

MALL4CLOUD_APP_DIR=/opt/mall4cloud
MALL4CLOUD_DATA_DIR=/data/mall4cloud

MYSQL_ROOT_PASSWORD=80jpnH4.r5g
REDIS_PASSWORD=80jpnH4.r5g
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=80jpnH4.r5g
ELASTIC_PASSWORD=80jpnH4.r5g
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos
